{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },

  "Keycloak": {
    "Enabled": false,
    "Authority": "http://localhost:8082/auth/realms/erp",
    "Audience": "account"
  },

  "ReverseProxy": {
    "Routes": {

      "retail-sales-route": {
        "ClusterId": "retail",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/v1/sales/{**catch-all}"
        }
      },

      "retail-pricing-route": {
        "ClusterId": "retail",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/v1/pricing/{**catch-all}"
        }
      },

      "inventory-route": {
        "ClusterId": "inventory",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/v1/inventory/{**catch-all}"
        }
      },

      "catalogs-route": {
        "ClusterId": "catalogs",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/v1/catalogs/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/v1/catalogs" },
          { "PathPrefix": "/api/v1" }
        ]
      },

      "crm-route": {
        "ClusterId": "crm",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/v1/customers/{**catch-all}"
        }
      },

      "credit-route": {
        "ClusterId": "credit",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/v1/credit/{**catch-all}"
        }
      },

      "factura-route": {
        "ClusterId": "factura",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/v1/factura/{**catch-all}"
        }
      }
    },

    "Clusters": {

      "retail": {
        "Destinations": {
          "retail/primary": {
            "Address": "http://localhost:5236"
          }
        }
      },

      "inventory": {
        "Destinations": {
          "inventory/primary": {
            "Address": "http://localhost:5010"
          }
        }
      },

      "catalogs": {
        "Destinations": {
          "catalogs/primary": {
            "Address": "http://localhost:5181"
          }
        }
      },

      "crm": {
        "Destinations": {
          "crm/primary": {
            "Address": "http://localhost:5156"
          }
        }
      },

      "credit": {
        "Destinations": {
          "credit/primary": {
            "Address": "http://localhost:5041"
          }
        }
      },

      "factura": {
        "Destinations": {
          "factura/primary": {
            "Address": "http://localhost:5176"
          }
        }
      }
    }
  }
}
